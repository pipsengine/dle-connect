{
  "name": "dle-connect-iis-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" node node_modules/next/dist/bin/next dev apps/dashboard -p 3010",
    "dev:3020": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Restart-DashboardDev.ps1 -Port 3020",
    "dev:3020:only": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" node node_modules/next/dist/bin/next dev apps/dashboard -p 3020 -H 127.0.0.1",
    "dev:3020:clean": "npm run clean && npm run dev:3020:only",
    "dev:3020:restart": "npm run dev:3020",
    "dev:all": "npm run dev",
    "build": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" node node_modules/next/dist/bin/next build apps/dashboard",
    "start": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" node node_modules/next/dist/bin/next start apps/dashboard -p 3010",
    "publish:iis": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Publish-DleDashboardIis.ps1",
    "repair:iis": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Repair-DleDashboardIis.ps1",
    "deploy:server": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Deploy-ServerDashboard.ps1 -SkipInstall",
    "deploy:server:dev": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Deploy-ServerDashboard.ps1 -DevOnly",
    "repair:git-sync": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Repair-GitSync.ps1",
    "sync:mail-env": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Sync-MailEnvironment.ps1 -InternalServer",
    "verify:mail": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json apps/dashboard/scripts/send-branded-fleet-test.mts P0146",
    "start:iis": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" powershell -NoProfile -ExecutionPolicy Bypass -File deployment/iis/Start-DleDashboard.ps1",
    "lint": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" node node_modules/eslint/bin/eslint.js apps/dashboard --ignore-pattern **/.next --ignore-pattern **/node_modules",
    "clean": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" node -e \"require('fs').rmSync('apps/dashboard/.next',{recursive:true,force:true}); console.log('Cleaned apps/dashboard/.next');\"",
    "export:sage-timesheet": "node scripts/database/export-sage-contract-timesheet.js",
    "sync:sage-payroll-deductions": "node scripts/database/sync-sage-payroll-deductions.js --apply",
    "audit:sage-payroll-deductions": "node scripts/database/sync-sage-payroll-deductions.js --audit-only",
    "sync:nhf-from-sage-snapshot": "node scripts/sync-nhf-from-sage-snapshot.mjs",
    "reconcile:payroll-deductions": "node scripts/reconcile-payroll-deductions.mjs",
    "reconcile:runtime-payroll": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json apps/dashboard/scripts/reconcile-runtime-payroll.mts",
    "sync:sage-earning-adjustments": "node scripts/sync-sage-earning-adjustments.mjs",
    "verify:leave-workflow": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/verify-leave-workflow.mts",
    "verify:leave-approver-routing": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/verify-leave-approver-routing.mts",
    "sync:department-reporting-managers": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/sync-department-reporting-managers.ts",
    "apply:administration-reporting-lines": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/apply-administration-reporting-lines.mts",
    "reset:nysc0032-leave": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/reset-nysc0032-leave.mts",
    "audit:department-reporting-managers": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/sync-department-reporting-managers.ts --summary",
    "smoke:p0146-leave": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/smoke-test-p0146-leave.mts",
    "verify:performance-calculation": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/verify-performance-calculation.mts",
    "verify:performance-sql-cutover": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/verify-performance-sql-cutover.mts",
    "import:performance-domain-sql": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/import-performance-domain-sql.mts",
    "smoke:performance-domain": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/smoke-performance-domain.mts",
    "smoke:performance-sql": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/smoke-performance-sql.mts",
    "worker:performance": "call \"%npm_package_json%\\..\\scripts\\Run-FromRepo.cmd\" npx --yes tsx --tsconfig apps/dashboard/tsconfig.json scripts/run-performance-workers.mts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "mssql": "^12.5.5",
    "mysql2": "^3.22.5",
    "next": "^15.4.9",
    "ng-locations": "^1.0.0",
    "nodemailer": "^7.0.13",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
