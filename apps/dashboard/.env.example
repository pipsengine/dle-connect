# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL used in workflow approval emails (leave, payroll, overtime).
# Set this to the address approvers can actually open — e.g. http://192.168.5.5:3020 on the LAN,
# http://localhost:3020 for local dev, or https://connect.dormanlong.ng in production.
# If unset on internal IIS (DLE_DEPLOY_ENV=internal), links default to http://{DLE_ENTERPRISE_DB_HOST}:3020.
APP_URL="https://connect.dormanlong.ng"
NEXT_PUBLIC_APP_URL="https://connect.dormanlong.ng"
# Optional explicit override for workflow email links (takes priority over APP_URL).
# DLE_PUBLIC_APP_URL="http://192.168.5.5:3020"
# DLE_INTERNAL_APP_URL="http://192.168.5.5:3020"

# Session + signed email approval links (payroll, leave). Use a long random secret in production.
AUTH_SESSION_SECRET="CHANGE_ME_BEFORE_PRODUCTION"

# Mail provider: graph (Microsoft Graph API) | smtp | auto (default: graph if configured, else smtp)
DLE_MAIL_PROVIDER="graph"

# ── Microsoft Graph API (recommended — works when SMTP basic auth is disabled) ──
# Azure app registration (Entra ID → App registrations → New registration):
#   Name: DLE Connect Mail
#   Supported account types: Single tenant
# API permissions (Application) → Add → Microsoft Graph → Mail.Send → Grant admin consent
# Certificates & secrets → New client secret → copy value into MS_GRAPH_CLIENT_SECRET
# Optional but recommended: restrict app to dleconnect mailbox only (Exchange Application Access Policy)
#   New-ApplicationAccessPolicy -AppId {client-id} -PolicyScopeGroupId {group-with-dleconnect} -AccessRight RestrictAccess
MS_GRAPH_TENANT_ID="YOUR_AZURE_TENANT_ID"
MS_GRAPH_CLIENT_ID="YOUR_AZURE_APP_CLIENT_ID"
MS_GRAPH_CLIENT_SECRET="YOUR_AZURE_APP_CLIENT_SECRET"
MS_GRAPH_SENDER_EMAIL="dleconnect@dormanlongeng.com"
# MS_GRAPH_SCOPE="https://graph.microsoft.com/.default"

# ── Microsoft 365 SMTP (fallback — requires Authenticated SMTP + basic auth allowed) ──
# Host: smtp.office365.com | Port: 587 | STARTTLS (DLE_SMTP_SECURE=false)
# Prerequisites in Microsoft 365 admin:
#   1. Dedicated mailbox (e.g. noreply@yourdomain.com) or shared mailbox with Send As
#   2. SMTP AUTH enabled for that mailbox (Exchange admin → mailbox → Email apps → Authenticated SMTP)
#   3. If MFA is on the mailbox, use an App Password (or configure OAuth2 — not yet supported here)
#   4. SPF/DKIM/DMARC configured for your domain (improves deliverability)
DLE_SMTP_HOST="smtp.office365.com"
DLE_SMTP_PORT="587"
DLE_SMTP_SECURE="false"
DLE_SMTP_REQUIRE_TLS="true"
DLE_SMTP_USER="dleconnect@dormanlongeng.com"
DLE_SMTP_PASSWORD="YOUR_MAILBOX_OR_APP_PASSWORD"
DLE_SMTP_FROM="DLE Connect <dleconnect@dormanlongeng.com>"
DLE_SMTP_REPLY_TO="dleconnect@dormanlongeng.com"

# Payroll approval — fallback when approver has no email in the user directory
PAYROLL_APPROVAL_FALLBACK_EMAIL="dleconnect@dormanlongeng.com"

# Sage 300 People Payroll SQL Server connection (legacy source — migrate into DLE_Enterprise).
# Server: 192.168.5.8 | Database: DLE_JUNE | Expires: 2026-08-31
SAGE_PAYROLL_DB_HOST="192.168.5.8"
SAGE_PAYROLL_DB_PORT="1433"
SAGE_PAYROLL_DB_INSTANCE="MSSQLSERVERPEOPL"
SAGE_PAYROLL_DB_NAME="DLE_JUNE"
SAGE_PAYROLL_DB_USER="sa"
SAGE_PAYROLL_DB_PASSWORD="YOUR_SAGE_PAYROLL_PASSWORD"

# Payroll run controls.
HRIS_ACTIVE_PAYROLL_PERIOD="2026-06"
HRIS_NEXT_PAYROLL_PERIOD="2026-07"
# From this period onward, payroll is 100% DLE_Enterprise — Sage is migration-only.
HRIS_PAYROLL_ENTERPRISE_FROM="2026-06"

# Primary DLE Enterprise SQL Server database connection (HRIS target system).
# Production server: 192.168.5.5 | Use host.docker.internal only for local Docker dev.
DLE_ENTERPRISE_DB_HOST="192.168.5.5"
DLE_ENTERPRISE_DB_ENABLED="true"
DLE_ENTERPRISE_DB_PORT="1433"
DLE_ENTERPRISE_DB_NAME="DLE_Enterprise"
DLE_ENTERPRISE_DB_USER="sa"
DLE_ENTERPRISE_DB_PASSWORD="YOUR_DLE_ENTERPRISE_PASSWORD"
DLE_ENTERPRISE_DB_ENCRYPT="true"
DLE_ENTERPRISE_DB_TRUST_SERVER_CERTIFICATE="true"
DLE_ENTERPRISE_DB_CONNECTION_TIMEOUT_MS="20000"
DLE_ENTERPRISE_DB_REQUEST_TIMEOUT_MS="60000"
DLE_ENTERPRISE_DB_POOL_MIN="2"
DLE_ENTERPRISE_DB_POOL_MAX="10"
DLE_ENTERPRISE_DB_POOL_IDLE_TIMEOUT_MS="120000"

# Employee source caching — keeps DLE_Enterprise reads in memory between requests.
HRIS_DIRECTORY_CACHE_MS="600000"
HRIS_DIRECTORY_DB_CACHE_MS="300000"
HRIS_EMPLOYEE_SOURCE_CACHE_MS="300000"
HRIS_EMPLOYEE_SOURCE_STALE_MS="1800000"
HRIS_EMPLOYEE_SOURCE_DB_TIMEOUT_MS="30000"
# Timesheet full-table reads (headers, lines, allocations) — cached per process.
HRIS_TIMESHEET_DATA_CACHE_MS="60000"
HRIS_TIMESHEET_APPROVAL_STATS_CACHE_MS="60000"
HRIS_TIMESHEET_APPROVAL_EMPLOYEE_CACHE_MS="300000"
# Deploy target: internal (192.168.5.5 UAT), staging, uat, or production.
# internal enables timesheet overtime test features on IIS (NODE_ENV=production)
# and defaults workflow email links to http://192.168.5.5:3020 when APP_URL is not set.
DLE_DEPLOY_ENV="internal"
# Timesheet overtime booking — on by default in non-production and DLE_DEPLOY_ENV=internal. Set false before public go-live.
HRIS_TIMESHEET_OVERTIME_BOOKING_ENABLED="true"
# Relaxed local E2E rules (PM-approved counts; synthetic auth when none exist). Keep false in production.
HRIS_TIMESHEET_OVERTIME_DEV_RELAXED="true"
# Book OT on approved/posted timesheets and refresh payroll feed (June corrections). Keep false in production.
HRIS_TIMESHEET_OVERTIME_RETRO_CORRECTION="true"
# Open OT booking without MD authorization (test/reconciliation until go-live). Set false on production deploy.
HRIS_TIMESHEET_OVERTIME_OPEN_BOOKING="true"
# Leave management — defer heavy ESS upsert / balance sync on dashboard GET.
HRIS_ESS_LEAVE_SYNC_MS="300000"
HRIS_LEAVE_BALANCE_SYNC_MS="300000"
HRIS_LEAVE_TYPE_POLICY_SYNC_MS="3600000"
HRIS_SAGE_LEAVE_SYNC_MS="900000"
# Live Sage payroll enrichment hits 192.168.5.8 on every employee load when enabled.
# Keep false now that payroll data is stored in DLE_Enterprise; set true only for live Sage payslip variance checks.
HRIS_SAGE_PAYROLL_ENRICH="false"
SAGE_PAYROLL_ENRICH_TIMEOUT_MS="20000"

# Production payroll must use the HRIS database employee source.
# Keep this true for go-live; set false only for local demos where cached timesheet data is acceptable.
HRIS_REQUIRE_DB_EMPLOYEE_SOURCE="true"
HRIS_MIN_EMPLOYEE_SOURCE_COUNT="100"

# Payroll runs and periods are persisted to DLE_Enterprise (192.168.5.5) by default.
# Set HRIS_PAYROLL_REQUIRE_SQL=false only for offline demos without SQL Server.
HRIS_PAYROLL_REQUIRE_SQL="true"
# Optional local JSON mirror for debugging — keep false in production.
HRIS_PAYROLL_JSON_MIRROR="false"
# May cutover: defer timesheet/pension/Sage variance checks for listed periods (comma-separated YYYY-MM).
# Set HRIS_PAYROLL_TOLERANCE_MODE=false to enforce full validation.
HRIS_PAYROLL_TOLERANCE_PERIODS="2026-05"
